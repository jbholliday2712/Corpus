# Same Supabase project the pipeline writes to. Service key, not the
# publishable/anon key — this app is local-only trusted tooling (see
# STATUS.md), and reads/writes documents+chunks directly server-side.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# For the "Retry" button: points at the pipeline's Python so it can shell
# out to `corpus retry <id>` in the background. CORPUS_PYTHON is the venv's
# python executable (the one with `corpus` installed via `pip install -e .`),
# CORPUS_PIPELINE_DIR is the pipeline/ directory itself.
CORPUS_PYTHON=../pipeline/.venv/bin/python
CORPUS_PIPELINE_DIR=../pipeline
